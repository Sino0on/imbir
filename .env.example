SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=*

# Настройки базы данных
DB_ENGINE=postgresql
DB_NAME=imbir
DB_USER=imbir_user
DB_PASSWORD=imbir_password
DB_HOST=db
DB_PORT=5432

# Nikita SMS settings
NIKITA_SMS_URL=https://smspro.nikita.kg/api/send
NIKITA_SMS_LOGIN=your_nikita_login_here
NIKITA_SMS_PASSWORD=your_nikita_password_here
NIKITA_SMS_SENDER=Imbir

# Celery
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# LiveKit
LIVEKIT_URL=wss://your-livekit-instance.example.com
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_TOKEN_TTL_MINUTES=15
LIVEKIT_JOIN_WINDOW_MINUTES=15
LIVEKIT_RECORDING_ENABLED=True
LIVEKIT_RECORDING_LOCAL_PATH=/out/{room_name}-{time}.mp4
LIVEKIT_S3_ACCESS_KEY=
LIVEKIT_S3_SECRET_KEY=
LIVEKIT_S3_BUCKET=
LIVEKIT_S3_REGION=
LIVEKIT_S3_ENDPOINT=

